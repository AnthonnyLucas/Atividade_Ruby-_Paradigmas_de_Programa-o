# Gemfile — lista as dependências (bibliotecas) do projeto
# Para instalar tudo, execute no terminal: bundle install
 
source 'https://rubygems.org'
 
gem 'sinatra'   # Framework web para criar o servidor
gem 'json'      # Suporte a JSON (já vem com Ruby, mas declaramos por segurança)
gem 'rackup'    # Necessário para o Sinatra 4+ iniciar o servidor
gem 'puma'      # Servidor web que o Sinatra usa para rodar a aplicação
